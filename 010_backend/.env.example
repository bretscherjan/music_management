# Server Configuration
PORT=3004
NODE_ENV=development

# Database (MySQL via Prisma)
DATABASE_URL="mysql://user:password@localhost:3306/vereinsdb"

# JWT Configuration
JWT_SECRET="your-super-secret-key-change-in-production"
JWT_EXPIRES_IN="7d"

# SMTP Configuration (Nodemailer)
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="user@example.com"
SMTP_PASS="password"
SMTP_FROM="Musig Elgg <noreply@example.com>"

# File Upload
UPLOAD_DIR="uploads"
MAX_FILE_SIZE=10485760

# OnlyOffice Configuration
ONLYOFFICE_SECRET="your-onlyoffice-jwt-secret"
ONLYOFFICE_CALLBACK_HOST="https://your-domain.com"
ONLYOFFICE_DOCUMENT_SERVER="https://your-onlyoffice-server:8888"
