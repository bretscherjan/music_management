# ─────────────────────────────────────────────────────────────────────────────
# Music Management — Docker Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ── MySQL ─────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=music_management
MYSQL_USER=app_user
MYSQL_PASSWORD=change_me_password

# ── Backend ───────────────────────────────────────────────────────────────────
PORT=3004
NODE_ENV=production

# DATABASE_URL is auto-composed from MYSQL_* vars in docker-compose.yml
# For local dev outside Docker, set it manually:
# DATABASE_URL="mysql://app_user:change_me_password@localhost:3306/music_management"

JWT_SECRET=change_me_jwt_secret_min_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# CORS: comma-separated list of allowed origins
CORS_ORIGIN=http://localhost,http://localhost:80

# SMTP (for email notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=user@example.com
SMTP_PASS=password
SMTP_FROM="Music Management <noreply@example.com>"

# File uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE=524288000

# ── Frontend ──────────────────────────────────────────────────────────────────
# Leave empty when running behind the Nginx reverse proxy (default)
# Set to the public backend URL when frontend is hosted separately
VITE_API_URL=

# ── Whisper AI ────────────────────────────────────────────────────────────────
# Available models: tiny, base, small, medium, large
WHISPER_MODEL=base

# Whisper URL for the backend to call
WHISPER_URL=http://whisper:8000

# ── Ollama AI ─────────────────────────────────────────────────────────────────
OLLAMA_URL=http://ollama:11434
