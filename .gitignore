# ── Ollama ───────────────────────────────────────────────────────────────────
# Model weights, SSH keys and cache generated by ollama at runtime (~GB range)
deployment/ollama/models/*
!deployment/ollama/models/.gitkeep

# ── Whisper ──────────────────────────────────────────────────────────────────
# Downloaded model weights (can be several GB per model)
deployment/whisper/models/*
!deployment/whisper/models/.gitkeep

# Transcription output files
deployment/whisper/outputs/*
!deployment/whisper/outputs/.gitkeep

# ── OS / Editor ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

.idea/
.vscode/
*.swp
*.swo
