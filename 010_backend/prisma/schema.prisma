generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                   Int                   @id @default(autoincrement())
  email                String                @unique
  password             String
  firstName            String
  lastName             String
  profilePicture       String?
  status               UserStatus            @default(active)
  role                 UserRole              @default(member)
  registerId           Int?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  phoneNumber          String?
  calendarToken        String?               @unique
  resetToken           String?               @unique
  resetTokenExpiry     DateTime?
  ownedNotes           AdminNote[]           @relation("NoteOwner")
  attendances          Attendance[]
  fileAccess           FileAccess[]
  folderAccess         FolderAccess[]
  news                 News[]
  noteContributions    NoteContribution[]
  notificationSettings NotificationSettings?
  pushSubscriptions    PushSubscription[]
  sheetMusicBookmarks  SheetMusicBookmark[]
  tasksCompleted       Task[]                @relation("TaskCompleter")
  tasksCreated         Task[]                @relation("TaskCreator")
  taskHistory          TaskHistory[]
  register             Register?             @relation(fields: [registerId], references: [id])
  verifiedAttendances  VerifiedAttendance[]

  @@index([email])
  @@index([registerId])
}

model NotificationSettings {
  id                     Int      @id @default(autoincrement())
  userId                 Int      @unique
  notifyOnEventCreate    Boolean  @default(true)
  notifyOnEventUpdate    Boolean  @default(true)
  notifyOnEventDelete    Boolean  @default(true)
  notifyOnFileUpload     Boolean  @default(true)
  notifyOnFileDelete     Boolean  @default(false)
  updatedAt              DateTime @updatedAt
  pushEventCancellations Boolean  @default(true)
  pushEventUpdates       Boolean  @default(true)
  pushFileDeleted        Boolean  @default(false)
  pushNewEvents          Boolean  @default(true)
  pushNewFiles           Boolean  @default(true)
  reminderSettings       Json?
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Register {
  id           Int            @id @default(autoincrement())
  name         String         @unique
  files        File[]
  fileAccess   FileAccess[]
  folderAccess FolderAccess[]
  users        User[]
  events       Event[]        @relation("EventToRegister")

  @@index([name])
}

model Event {
  id                    Int                  @id @default(autoincrement())
  title                 String
  description           String?              @db.Text
  location              String?
  category              EventCategory        @default(other)
  visibility            EventVisibility      @default(all)
  date                  DateTime
  startTime             String
  endTime               String
  isRecurring           Boolean              @default(false)
  recurrenceRule        String?
  excludedDates         Json?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  responseDeadlineHours Int                  @default(48)
  setlistEnabled        Boolean              @default(false)
  isPublic              Boolean              @default(false)
  attendances           Attendance[]
  sheetMusic            EventSheetMusic[]
  files                 File[]
  workspaceTasks        Task[]
  verifiedAttendances   VerifiedAttendance[]
  targetRegisters       Register[]           @relation("EventToRegister")

  @@index([date])
  @@index([category])
}

model Attendance {
  id        Int              @id @default(autoincrement())
  status    AttendanceStatus @default(maybe)
  comment   String?          @db.Text
  eventId   Int
  userId    Int
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  event     Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}

model File {
  id               Int              @id @default(autoincrement())
  filename         String
  originalName     String
  path             String
  mimetype         String
  size             Int
  visibility       FileVisibility   @default(all)
  targetRegisterId Int?
  eventId          Int?
  createdAt        DateTime         @default(now())
  folder           String           @default("/")
  folderId         Int?
  sheetMusicId     Int?
  event            Event?           @relation(fields: [eventId], references: [id])
  realFolder       Folder?          @relation(fields: [folderId], references: [id])
  sheetMusic       SheetMusic?      @relation(fields: [sheetMusicId], references: [id])
  targetRegister   Register?        @relation(fields: [targetRegisterId], references: [id])
  accessRules      FileAccess[]
  shareTokens      FileShareToken[]

  @@index([visibility])
  @@index([targetRegisterId])
  @@index([eventId])
  @@index([folder])
  @@index([folderId], map: "File_folderId_fkey")
  @@index([sheetMusicId], map: "File_sheetMusicId_fkey")
}

model FileAccess {
  id         Int              @id @default(autoincrement())
  fileId     Int
  accessType AccessType       @default(ALLOW)
  targetType AccessTargetType
  userId     Int?
  registerId Int?
  createdAt  DateTime         @default(now())
  file       File             @relation(fields: [fileId], references: [id], onDelete: Cascade)
  register   Register?        @relation(fields: [registerId], references: [id], onDelete: Cascade)
  user       User?            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([fileId])
  @@index([userId])
  @@index([registerId])
}

model News {
  id        Int      @id @default(autoincrement())
  title     String
  content   String   @db.Text
  authorId  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([authorId])
  @@index([createdAt])
}

model Setting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String

  @@index([key])
}

model SheetMusic {
  id          Int                  @id @default(autoincrement())
  title       String
  composer    String?
  arranger    String?
  genre       String?
  difficulty  Difficulty?
  publisher   String?
  notes       String?              @db.Text
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  events      EventSheetMusic[]
  files       File[]
  folderItems MusicFolderItem[]
  bookmarks   SheetMusicBookmark[]

  @@index([title])
  @@index([genre])
  @@index([difficulty])
}

model SheetMusicBookmark {
  id           Int        @id @default(autoincrement())
  userId       Int
  sheetMusicId Int
  createdAt    DateTime   @default(now())
  sheetMusic   SheetMusic @relation(fields: [sheetMusicId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sheetMusicId])
  @@index([userId])
  @@index([sheetMusicId])
}

model EventSheetMusic {
  id                Int             @id @default(autoincrement())
  eventId           Int
  sheetMusicId      Int?
  position          Int             @default(0)
  createdAt         DateTime        @default(now())
  customDescription String?         @db.Text
  customTitle       String?
  duration          Int?
  type              SetlistItemType @default(sheetMusic)
  event             Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  sheetMusic        SheetMusic?     @relation(fields: [sheetMusicId], references: [id], onDelete: Cascade)

  @@unique([eventId, position])
  @@index([eventId])
  @@index([sheetMusicId])
}

model PushSubscription {
  id        Int      @id @default(autoincrement())
  userId    Int
  endpoint  String   @unique @db.VarChar(500)
  p256dh    String   @db.Text
  auth      String   @db.Text
  userAgent String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Folder {
  id          Int            @id @default(autoincrement())
  name        String
  parentId    Int?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  files       File[]
  parent      Folder?        @relation("FolderToFolder", fields: [parentId], references: [id], onDelete: Cascade)
  children    Folder[]       @relation("FolderToFolder")
  accessRules FolderAccess[]

  @@unique([name, parentId])
  @@index([parentId])
}

model FolderAccess {
  id         Int              @id @default(autoincrement())
  folderId   Int
  accessType AccessType       @default(ALLOW)
  targetType AccessTargetType
  userId     Int?
  registerId Int?
  createdAt  DateTime         @default(now())
  folder     Folder           @relation(fields: [folderId], references: [id], onDelete: Cascade)
  register   Register?        @relation(fields: [registerId], references: [id], onDelete: Cascade)
  user       User?            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([folderId])
  @@index([userId])
  @@index([registerId])
}

model VerifiedAttendance {
  id        Int                @id @default(autoincrement())
  eventId   Int
  userId    Int
  status    VerificationStatus
  comment   String?
  updatedAt DateTime           @updatedAt
  adminId   Int
  event     Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}

model MusicFolder {
  id          Int               @id @default(autoincrement())
  name        String
  description String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  items       MusicFolderItem[]
}

model MusicFolderItem {
  id           Int         @id @default(autoincrement())
  folderId     Int
  sheetMusicId Int
  position     Int         @default(0)
  folder       MusicFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  sheetMusic   SheetMusic  @relation(fields: [sheetMusicId], references: [id], onDelete: Cascade)

  @@unique([folderId, sheetMusicId])
  @@index([folderId])
  @@index([sheetMusicId])
}

model TaskCategory {
  id        Int      @id @default(autoincrement())
  name      String
  color     String?
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tasks     Task[]

  @@index([position])
}

model Task {
  id            Int           @id @default(autoincrement())
  title         String
  description   String?       @db.Text
  priority      TaskPriority  @default(medium)
  dueDate       DateTime?
  completed     Boolean       @default(false)
  completedAt   DateTime?
  archived      Boolean       @default(false)
  position      Int           @default(0)
  categoryId    Int
  parentId      Int?
  eventId       Int?
  createdById   Int
  completedById Int?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  category      TaskCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  completedBy   User?         @relation("TaskCompleter", fields: [completedById], references: [id])
  createdBy     User          @relation("TaskCreator", fields: [createdById], references: [id])
  event         Event?        @relation(fields: [eventId], references: [id])
  parent        Task?         @relation("TaskSubtasks", fields: [parentId], references: [id], onDelete: Cascade)
  subtasks      Task[]        @relation("TaskSubtasks")
  history       TaskHistory[]

  @@index([categoryId])
  @@index([parentId])
  @@index([eventId])
  @@index([completed])
  @@index([archived])
  @@index([position])
  @@index([completedById], map: "Task_completedById_fkey")
  @@index([createdById], map: "Task_createdById_fkey")
}

model TaskHistory {
  id        Int      @id @default(autoincrement())
  taskId    Int
  userId    Int
  action    String
  details   Json?
  createdAt DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@index([taskId])
  @@index([userId])
  @@index([createdAt])
}

model AdminNote {
  id            Int                @id @default(autoincrement())
  title         String
  content       String             @db.LongText
  ownerId       Int
  pinned        Boolean            @default(false)
  position      Int                @default(0)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  owner         User               @relation("NoteOwner", fields: [ownerId], references: [id])
  contributions NoteContribution[]

  @@index([ownerId])
  @@index([pinned])
  @@index([position])
}

model NoteContribution {
  id        Int       @id @default(autoincrement())
  noteId    Int
  userId    Int
  charCount Int       @default(0)
  updatedAt DateTime  @updatedAt
  note      AdminNote @relation(fields: [noteId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id])

  @@unique([noteId, userId])
  @@index([noteId])
  @@index([userId])
}

model FileShareToken {
  id         Int      @id @default(autoincrement())
  token      String   @unique
  fileId     Int
  createdAt  DateTime @default(now())
  expiresAt  DateTime
  usageCount Int      @default(0)
  file       File     @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([fileId], map: "FileShareToken_fileId_fkey")
}

model Sponsor {
  id          Int      @id @default(autoincrement())
  name        String
  logoUrl     String
  websiteUrl  String?
  active      Boolean  @default(true)
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  description String?  @db.Text

  @@index([active])
  @@index([position])
}

model GalleryImage {
  id          Int      @id @default(autoincrement())
  filename    String
  title       String?
  description String?  @db.Text
  category    String?
  active      Boolean  @default(true)
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active])
  @@index([position])
  @@index([createdAt])
}

model Flyer {
  id             Int       @id @default(autoincrement())
  filename       String
  title          String
  activeFrom     DateTime?
  activeTo       DateTime?
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  description    String?   @db.Text
  position       Int       @default(0)
  showOnHomePage Boolean   @default(false)

  @@index([active])
  @@index([showOnHomePage])
  @@index([position])
}

enum UserStatus {
  active
  passive
  former
}

enum UserRole {
  member
  admin
}

enum EventCategory {
  rehearsal
  performance
  other
}

enum EventVisibility {
  all
  register
  admin
}

enum AttendanceStatus {
  yes
  no
  maybe
}

enum FileVisibility {
  all
  limit
  admin
  register
}

enum AccessType {
  ALLOW
  DENY
}

enum AccessTargetType {
  USER
  REGISTER
  ADMIN_ONLY
}

enum Difficulty {
  easy
  medium
  hard
}

enum SetlistItemType {
  sheetMusic
  pause
  custom
}

enum VerificationStatus {
  PRESENT
  EXCUSED
  UNEXCUSED
}

enum TaskPriority {
  low
  medium
  high
}
